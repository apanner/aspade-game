# Storage (Supabase S3-compatible — copy values from asapde_vercel_v2 / Vercel dashboard)
STORAGE_PROVIDER=s3
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=score
S3_ENDPOINT=
S3_REGION=us-east-2

# Live mode
NEXT_PUBLIC_LIVE_MODE_ENABLED=true

# Optional: Supabase Realtime (instant sync; polling works without these)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
